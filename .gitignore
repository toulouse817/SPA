# Archivo .gitignore para un proyecto web de JavaScript Vanilla y Frontend

# Dependencias y paquetes (por si se agregan herramientas en el futuro)
node_modules/
jspm_packages/
web_modules/

# Archivos de compilación y salida (opcional si se usa bundler más adelante)
dist/
build/
out/
.cache/
.sass-cache/

# Archivos de registro de errores y depuración (Logs)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Configuraciones del Entorno de Desarrollo (IDEs y Editores)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# Archivos del Sistema Operativo
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini
